# config.js
msgid "USB Gadget Configuration"
msgstr "Настройка USB-гаджета"

msgid "Configure USB gadget functions. Changes take effect after saving and restarting the service."
msgstr "Настройка функций USB-гаджета. Изменения вступят в силу после сохранения и перезапуска службы."

msgid "Device Settings"
msgstr "Параметры устройства"

msgid "Enable USB Gadget"
msgstr "Включить USB-гаджет"

msgid "Disable to use USB port in host mode."
msgstr "Отключите для использования USB-порта в режиме хоста."

msgid "Ensure alternative access."
msgstr "Обеспечьте альтернативный доступ."

msgid "Gadget Name"
msgstr "Имя гаджета"

msgid "Manufacturer"
msgstr "Производитель"

msgid "Product"
msgstr "Продукт"

msgid "Vendor ID"
msgstr "Идентификатор производителя"

msgid "Must be hex format: 0x1234"
msgstr "Должен быть в шестнадцатеричном формате: 0x1234"

msgid "Product ID"
msgstr "Идентификатор продукта"

msgid "UDC Device"
msgstr "Устройство UDC"

msgid "Auto-detect"
msgstr "Автоопределение"

msgid "RNDIS (Windows Ethernet)"
msgstr "RNDIS (Ethernet для Windows)"

msgid "Windows-compatible USB ethernet. Works on all Windows versions."
msgstr "USB-Ethernet, совместимый с Windows. Работает на всех версиях Windows."

msgid "Enable RNDIS"
msgstr "Включить RNDIS"

msgid "Plug-and-play on Windows. Automatically adds to LAN bridge."
msgstr "Plug-and-play в Windows. Автоматически добавляется в мост локальной сети."

msgid "ECM (macOS/Linux Ethernet)"
msgstr "ECM (Ethernet для macOS/Linux)"

msgid "For macOS ≤10.14 and Linux. Do not enable with NCM."
msgstr "Для macOS ≤10.14 и Linux. Не включать одновременно с NCM."

msgid "Enable ECM"
msgstr "Включить ECM"

msgid "CDC Ethernet for macOS and Linux. Disable RNDIS when using."
msgstr "CDC Ethernet для macOS и Linux. Отключите RNDIS при использовании."

msgid "NCM (Modern Ethernet)"
msgstr "NCM (современный Ethernet)"

msgid "Best performance. For Windows 11+, macOS ≥10.15, Linux."
msgstr "Наилучшая производительность. Для Windows 11+, macOS ≥10.15, Linux."

msgid "Enable NCM"
msgstr "Включить NCM"

msgid "Modern high-speed USB ethernet. Best choice for new systems."
msgstr "Современный высокоскоростной USB-Ethernet. Лучший выбор для новых систем."

msgid "ACM (Serial Console)"
msgstr "ACM (последовательная консоль)"

msgid "Provides /dev/ttyACM0 on host. Access: screen /dev/ttyACM0 115200"
msgstr "Создаёт /dev/ttyACM0 на хосте. Доступ: screen /dev/ttyACM0 115200"

msgid "Enable Serial Console"
msgstr "Включить последовательную консоль"

msgid "Enable Login Shell"
msgstr "Включить командную оболочку"

msgid "Provide shell access. Disable for raw TTY."
msgstr "Предоставить доступ к оболочке. Отключите для прямого TTY."

msgid "Connection Info"
msgstr "Информация о подключении"

msgid "Mass Storage"
msgstr "Накопитель"

msgid "Expose storage image as USB drive. Does not provide access to the device."
msgstr "Предоставляет образ хранилища как USB-накопитель. Не даёт доступа к самому устройству."

msgid "Enable Mass Storage"
msgstr "Включить накопитель"

msgid "Image Path"
msgstr "Путь к образу"

msgid "File will be created automatically if it doesn't exist."
msgstr "Файл будет создан автоматически, если не существует."

msgid "Image Size"
msgstr "Размер образа"

msgid "Used when creating (e.g., 512M, 1G, 2G)"
msgstr "Используется при создании (например: 512M, 1G, 2G)"

msgid "Read-Only"
msgstr "Только чтение"

msgid "Mount as read-only on the host computer"
msgstr "Монтировать в режиме только чтения на компьютере хоста"

msgid "Configuration saved. Restarting USB Gadget service..."
msgstr "Конфигурация сохранена. Перезапуск службы USB-гаджета..."

msgid "USB Gadget service restarted successfully"
msgstr "Служба USB-гаджета успешно перезапущена"

# overview.js
msgid "Gadget Status"
msgstr "Состояние гаджета"

msgid "Active (Device Mode)"
msgstr "Активен (режим устройства)"

msgid "Disabled (Host Mode)"
msgstr "Отключён (режим хоста)"

msgid "Enabled Functions"
msgstr "Активные функции"

msgid "None"
msgstr "Нет"

msgid "USB Controller"
msgstr "Контроллер USB"

msgid "Network Interfaces"
msgstr "Сетевые интерфейсы"

msgid "USB Gadget Status"
msgstr "Состояние USB-гаджета"

msgid "View current USB gadget configuration and status"
msgstr "Просмотр текущей конфигурации и состояния USB-гаджета"

msgid "Current Status"
msgstr "Текущее состояние"

msgid "Restarting service..."
msgstr "Перезапуск службы..."

msgid "Please wait..."
msgstr "Пожалуйста, подождите..."

msgid "Failed to restart: %s"
msgstr "Ошибка перезапуска: %s"

msgid "Restart Service"
msgstr "Перезапустить службу"
